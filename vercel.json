{
  "outputDirectory": "website",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/features",
      "destination": "/features.html"
    },
    {
      "source": "/commands",
      "destination": "/commands.html"
    },
    {
      "source": "/support",
      "destination": "/support.html"
    },
    {
      "source": "/styles.css",
      "destination": "/styles.css"
    },
    {
      "source": "/app.js",
      "destination": "/app.js"
    }
  ]
}
